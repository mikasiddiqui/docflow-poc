# Microsoft Graph app registration
DOCFLOW_GRAPH_TENANT_ID=your-tenant-id
DOCFLOW_GRAPH_CLIENT_ID=your-client-id
DOCFLOW_GRAPH_CLIENT_SECRET=your-client-secret

# Default drive IDs for Graph file lookup/upload.
# These are the document library drive IDs, not site IDs.
DOCFLOW_GRAPH_DRIVE_ID=your-input-drive-id
DOCFLOW_GRAPH_OUTPUT_DRIVE_ID=your-output-drive-id

# Local runtime settings
DOCFLOW_OUTPUT_DIR=output
DOCFLOW_LOG_LEVEL=INFO

# Reserved for later. The current mapper is deterministic only.
DOCFLOW_ENABLE_LLM_MAPPING=false
